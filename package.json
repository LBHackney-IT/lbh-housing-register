{
  "name": "hackney-housing-register",
  "version": "2.1.4",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "next build --webpack",
    "postbuild": "node scripts/prepare-lambda-standalone.cjs",
    "dev": "next dev --webpack --hostname=localdev.hackney.gov.uk",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier:test": "npx prettier -c .",
    "prettier:fix": "npx prettier --write .",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit && tsc --noEmit",
    "test": "jest && tsc --noEmit",
    "test:watch": "jest --watch",
    "commit": "czg",
    "prepare": "husky || true",
    "cypress:open": "E2E_HTTP_MOCKS=true cypress open --browser chrome",
    "cypress:open:local": "LOCAL_E2E=true cypress open --browser chrome",
    "e2e:run": "E2E_HTTP_MOCKS=true cypress run --e2e --browser electron",
    "e2e:run:local": "LOCAL_E2E=true cypress run --e2e --browser electron",
    "component:run": "cypress run --component --browser electron"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-ignore",
      "prettier --ignore-unknown --write"
    ],
    "!(*.js|*.jsx|*.ts|*.tsx|package-lock.json)": "prettier --ignore-unknown --write"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/nextjs": "^10.46.0",
    "axios": "^1.14.0",
    "cookie": "^1.1.1",
    "formik": "^2.4.9",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "lbh-frontend": "^3.6.1",
    "lodash": "^4.17.21",
    "nested-object-diff": "^1.1.0",
    "next": "^16.2.1",
    "next-redux-wrapper": "^8.1.0",
    "notifications-node-client": "^8.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "restana": "^4.9.9",
    "serve-static": "^1.16.3",
    "serverless-http": "^4.0.0",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.17.0",
    "@faker-js/faker": "^8.4.1",
    "@hackney/prettier-config": "^1.0.1",
    "@next/eslint-plugin-next": "^16.2.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/cookie": "^0.4.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/lodash": "^4.17.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "babel-jest": "^30.3.0",
    "cypress": "^15.13.0",
    "cz-git": "^1.12.0",
    "czg": "^1.12.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^3.6.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "mockdate": "^3.0.5",
    "nock": "^14.0.0-beta.11",
    "node-mocks-http": "^1.17.2",
    "playwright-webkit": "^1.58.2",
    "prettier": "^3.4.2",
    "sass": "^1.98.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "xml2js": "^0.6.2"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
